# ── Optional: in-character LLM voice ────────────────────────────────────
# If unset, each computer falls back to a hand-scripted question flow.
# The game still runs end-to-end without this.
ANTHROPIC_API_KEY=

# ── Optional: real on-chain writes to Arkiv (Braga testnet) ─────────────
# When set, the server-side wallet writes every reply as an Arkiv entity
# with attributes + ExpirationTime, and persists the final data-type
# entity for 30 days. Without it, entities are synthesised locally and
# the UI shows "local" instead of a tx hash.
#
# - Must be a 0x-prefixed (or unprefixed) 64-hex private key.
# - Fund the wallet with test GLM from https://braga.hoodi.arkiv.network/faucet/
# - NEVER commit a real key. NEVER expose this to the client.
ARKIV_PRIVATE_KEY=
